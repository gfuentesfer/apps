# Variables para Render → Web Service → Environment
# Copia los valores desde tu server/.env (Neon)

PGHOST=ep-xxxx-pooler.region.aws.neon.tech
PGPORT=5432
PGDATABASE=neondb
PGUSER=neondb_owner
PGPASSWORD=tu_password_neon
PGSSLMODE=require
NODE_ENV=production

# PORT lo asigna Render automáticamente.
