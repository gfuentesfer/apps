# =============================================================================
# Neon (nube) — opción A: variables PG* (las que usa psql / Neon Console)
# =============================================================================
PGHOST=ep-xxxx-pooler.region.aws.neon.tech
PGPORT=5432
PGDATABASE=neondb
PGUSER=neondb_owner
PGPASSWORD=tu_password
PGSSLMODE=require

# =============================================================================
# Neon — opción B: connection string (alternativa a PG*)
# =============================================================================
# DATABASE_URL=postgresql://USER:PASSWORD@ep-xxxx-pooler.region.aws.neon.tech/neondb?sslmode=require

# =============================================================================
# PostgreSQL local (solo si no hay PG* ni DATABASE_URL)
# =============================================================================
DB_HOST=localhost
DB_PORT=5432
DB_USER=tu_usuario
DB_PASSWORD=tu_password
DB_NAME=arrows

PORT=3000
